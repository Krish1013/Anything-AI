{
  "info": {
    "_postman_id": "task-manager-api-collection",
    "name": "TaskManager REST API v1",
    "description": "Complete API collection for Task Manager - JWT Auth + RBAC + CRUD",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:5000/api/v1" },
    { "key": "token", "value": "" }
  ],
  "item": [
    {
      "name": "Health Check",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": "http://localhost:5000/health",
            "description": "Check if the API server is running"
          },
          "response": [
            {
              "name": "OK",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"success\": true,\n  \"message\": \"API is running\",\n  \"environment\": \"development\",\n  \"timestamp\": \"2024-01-01T00:00:00.000Z\"\n}"
            }
          ]
        }
      ]
    },
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.success && res.data.token) {",
                  "  pm.collectionVariables.set('token', res.data.token);",
                  "  console.log('Token saved:', res.data.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"password\": \"password123\",\n  \"role\": \"user\"\n}"
            },
            "description": "Register a new user. Saves token to collection variable automatically."
          },
          "response": [
            {
              "name": "201 Created",
              "status": "Created",
              "code": 201,
              "body": "{\n  \"success\": true,\n  \"message\": \"Registration successful\",\n  \"data\": {\n    \"token\": \"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...\",\n    \"user\": {\n      \"id\": \"665abc123\",\n      \"name\": \"John Doe\",\n      \"email\": \"john@example.com\",\n      \"role\": \"user\",\n      \"createdAt\": \"2024-01-01T00:00:00.000Z\"\n    }\n  }\n}"
            },
            {
              "name": "409 Conflict",
              "status": "Conflict",
              "code": 409,
              "body": "{\n  \"success\": false,\n  \"message\": \"An account with this email already exists.\"\n}"
            },
            {
              "name": "400 Validation Error",
              "status": "Bad Request",
              "code": 400,
              "body": "{\n  \"success\": false,\n  \"message\": \"Validation failed\",\n  \"errors\": [\n    { \"field\": \"email\", \"message\": \"Please provide a valid email address\" }\n  ]\n}"
            }
          ]
        },
        {
          "name": "Register Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.success && res.data.token) {",
                  "  pm.collectionVariables.set('token', res.data.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Admin User\",\n  \"email\": \"admin@example.com\",\n  \"password\": \"admin123\",\n  \"role\": \"admin\"\n}"
            },
            "description": "Register a new admin user"
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.success && res.data.token) {",
                  "  pm.collectionVariables.set('token', res.data.token);",
                  "  console.log('Logged in. Token saved.');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "description": "Login with credentials. Token is saved automatically for subsequent requests."
          },
          "response": [
            {
              "name": "200 Success",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"success\": true,\n  \"message\": \"Login successful\",\n  \"data\": {\n    \"token\": \"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...\",\n    \"user\": {\n      \"id\": \"665abc123\",\n      \"name\": \"John Doe\",\n      \"email\": \"john@example.com\",\n      \"role\": \"user\"\n    }\n  }\n}"
            },
            {
              "name": "401 Unauthorized",
              "status": "Unauthorized",
              "code": 401,
              "body": "{\n  \"success\": false,\n  \"message\": \"Invalid email or password.\"\n}"
            }
          ]
        },
        {
          "name": "Get My Profile",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/auth/me",
            "description": "Get the currently authenticated user's profile"
          },
          "response": [
            {
              "name": "200 Success",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"success\": true,\n  \"message\": \"User profile retrieved\",\n  \"data\": {\n    \"user\": {\n      \"id\": \"665abc123\",\n      \"name\": \"John Doe\",\n      \"email\": \"john@example.com\",\n      \"role\": \"user\",\n      \"createdAt\": \"2024-01-01T00:00:00.000Z\"\n    }\n  }\n}"
            }
          ]
        }
      ]
    },
    {
      "name": "Tasks",
      "item": [
        {
          "name": "Create Task",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/tasks",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Implement authentication\",\n  \"description\": \"Set up JWT-based authentication for the API\",\n  \"status\": \"in-progress\"\n}"
            },
            "description": "Create a new task. Requires authentication."
          },
          "response": [
            {
              "name": "201 Created",
              "status": "Created",
              "code": 201,
              "body": "{\n  \"success\": true,\n  \"message\": \"Task created successfully\",\n  \"data\": {\n    \"task\": {\n      \"_id\": \"665def456\",\n      \"title\": \"Implement authentication\",\n      \"description\": \"Set up JWT-based authentication for the API\",\n      \"status\": \"in-progress\",\n      \"user\": \"665abc123\",\n      \"createdAt\": \"2024-01-01T00:00:00.000Z\",\n      \"updatedAt\": \"2024-01-01T00:00:00.000Z\"\n    }\n  }\n}"
            },
            {
              "name": "401 No Token",
              "status": "Unauthorized",
              "code": 401,
              "body": "{\n  \"success\": false,\n  \"message\": \"Access denied. No token provided.\"\n}"
            }
          ]
        },
        {
          "name": "Get All Tasks",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/tasks?page=1&limit=10",
              "query": [
                { "key": "page", "value": "1", "description": "Page number" },
                { "key": "limit", "value": "10", "description": "Items per page" },
                { "key": "status", "value": "", "description": "Filter by status: pending | in-progress | completed", "disabled": true }
              ]
            },
            "description": "Get tasks. Admins see all tasks; users see only their own tasks. Supports pagination and status filtering."
          },
          "response": [
            {
              "name": "200 Success",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"success\": true,\n  \"message\": \"Tasks retrieved successfully\",\n  \"data\": {\n    \"tasks\": [\n      {\n        \"_id\": \"665def456\",\n        \"title\": \"Implement authentication\",\n        \"description\": \"Set up JWT-based authentication\",\n        \"status\": \"in-progress\",\n        \"user\": { \"_id\": \"665abc123\", \"name\": \"John Doe\", \"email\": \"john@example.com\" },\n        \"createdAt\": \"2024-01-01T00:00:00.000Z\"\n      }\n    ],\n    \"pagination\": {\n      \"total\": 1,\n      \"page\": 1,\n      \"limit\": 10,\n      \"pages\": 1\n    }\n  }\n}"
            }
          ]
        },
        {
          "name": "Get Task by ID",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/tasks/665def456",
            "description": "Get a single task by ID. Users can only view their own tasks; admins can view any."
          },
          "response": [
            {
              "name": "200 Success",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"success\": true,\n  \"message\": \"Task retrieved successfully\",\n  \"data\": {\n    \"task\": {\n      \"_id\": \"665def456\",\n      \"title\": \"Implement authentication\",\n      \"description\": \"Set up JWT-based authentication\",\n      \"status\": \"in-progress\",\n      \"user\": { \"_id\": \"665abc123\", \"name\": \"John Doe\", \"email\": \"john@example.com\" },\n      \"createdAt\": \"2024-01-01T00:00:00.000Z\"\n    }\n  }\n}"
            },
            {
              "name": "404 Not Found",
              "status": "Not Found",
              "code": 404,
              "body": "{\n  \"success\": false,\n  \"message\": \"Task not found.\"\n}"
            },
            {
              "name": "403 Forbidden",
              "status": "Forbidden",
              "code": 403,
              "body": "{\n  \"success\": false,\n  \"message\": \"You do not have permission to view this task.\"\n}"
            }
          ]
        },
        {
          "name": "Update Task",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/tasks/665def456",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Implement authentication - Updated\",\n  \"status\": \"completed\"\n}"
            },
            "description": "Update a task. Users can only update their own tasks; admins can update any."
          },
          "response": [
            {
              "name": "200 Success",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"success\": true,\n  \"message\": \"Task updated successfully\",\n  \"data\": {\n    \"task\": {\n      \"_id\": \"665def456\",\n      \"title\": \"Implement authentication - Updated\",\n      \"status\": \"completed\"\n    }\n  }\n}"
            }
          ]
        },
        {
          "name": "Delete Task (Admin Only)",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/tasks/665def456",
            "description": "Delete a task. ADMIN ONLY. Non-admin users will receive 403."
          },
          "response": [
            {
              "name": "200 Deleted",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"success\": true,\n  \"message\": \"Task deleted successfully\"\n}"
            },
            {
              "name": "403 Forbidden (non-admin)",
              "status": "Forbidden",
              "code": 403,
              "body": "{\n  \"success\": false,\n  \"message\": \"Access forbidden. Required role(s): admin. Your role: user\"\n}"
            }
          ]
        }
      ]
    }
  ]
}
